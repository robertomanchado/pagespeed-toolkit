{
    "name": "inforob/pagespeed-toolkit",
    "type": "composer-plugin",
    "description": "Google PageSpeed Insights audit and AI-powered fix toolkit for Symfony projects",
    "keywords": ["symfony", "pagespeed", "lighthouse", "core-web-vitals", "performance", "seo"],
    "homepage": "https://github.com/inforob/claude-pagespeed-toolkit",
    "license": "MIT",
    "authors": [
        {
            "name": "inforob",
            "email": "roberto.inforob@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "composer-plugin-api": "^2.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/http-client": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Inforob\\PageSpeedToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Inforob\\PageSpeedToolkit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "class": "Inforob\\PageSpeedToolkit\\Composer\\Plugin"
    }
}
